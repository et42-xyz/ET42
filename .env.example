GENERATE_SOURCEMAP=false

# Backend API base URL
REACT_APP_API_HTTP_URL=https://api.example.com/

# Current environment: "dev" | "test" | "production"
REACT_APP_CURRENT_ENV=production

# Block explorer tx prefix (BSC by default)
REACT_APP_EXPLORER=https://bscscan.com/tx/

# Deployed marketplace contract address
REACT_APP_MARKETPLACE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# USDT (ERC-20) address used by the marketplace
REACT_APP_USDT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect / RainbowKit project id
REACT_APP_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID
